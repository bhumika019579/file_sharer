<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ThrowIt</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }

        body {
            background-image: url("/assets/bg.png");
            background-size: cover;
            background-repeat: no-repeat;
            background-position: center;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .landing {
            text-align: center;
            padding: 40px 20px;
        }

        .title {
            font-size: 96px;
            font-weight: 800;
            background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            line-height: 1;
            margin-bottom: 16px;
            letter-spacing: -3px;
        }

        .subtitle {
            font-size: 18px;
            color: #8e8e8e;
            margin-bottom: 40px;
            font-weight: 400;
        }

        .key-row {
            display: flex;
            gap: 0;
            max-width: 500px;
            margin: 0 auto 20px;
            border: 2px solid #dbdbdb;
            border-radius: 12px;
            overflow: hidden;
            background: white;
            transition: border-color 0.2s;
        }

        .key-row:focus-within {
            border-color: #dc2743;
        }

        .key-input {
            flex: 1;
            padding: 16px 20px;
            border: none;
            outline: none;
            font-size: 16px;
            color: #262626;
            background: transparent;
        }

        .key-input::placeholder { color: #c7c7c7; }

        .throw-btn {
            padding: 16px 28px;
            background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
            color: white;
            border: none;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            transition: opacity 0.2s;
            letter-spacing: 0.5px;
        }

        .throw-btn:hover { opacity: 0.9; }

        .no-login {
            font-size: 13px;
            color: #c7c7c7;
            margin-top: 16px;
            letter-spacing: 0.5px;
        }

        .no-login span {
            display: inline-block;
            margin-right: 6px;
        }
    </style>
</head>
<body>
    <div class="landing">
        <div class="title">ThrowIt</div>
        <div class="subtitle">simplest way to share files</div>

        <form action="/room" method="get">
            <div class="key-row">
                <input class="key-input"id="keyInput" type="text" name="key" placeholder="enter your secret key..." required autocomplete="off" spellcheck="false">
                <button type="button" onclick="enterRoom()" class="throw-btn">Throw →</button>
            </div>
        </form>

        <div class="no-login"><span>🔒</span> no login required</div>
    </div>
    <script>
        function enterRoom(){
            const key=document.getElementById('keyInput').value.trim();
            if(key){
                window.location.href=`/room/${encodeURIComponent(key)}`;

            }
            else{
                alert("please enter a key");
            }
            
        }
        document.getElementById('keyInput').addEventListener('keypress', (e) => {
        if (e.key === 'Enter') enterRoom();
    });
    </script>
</body>
</html>