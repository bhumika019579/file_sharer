<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>file upload</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        body {
            background: #fafafa;
            color: #262626;
        }

        /* Navbar */
        .navbar {
            background: white;
            border-bottom: 1px solid #dbdbdb;
            padding: 12px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .navbar h1 {
            font-size: 24px;
            font-weight: 700;
            background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .nav-buttons {
            display: flex;
            gap: 10px;
        }

        .btn {
            padding: 8px 16px;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            font-weight: 600;
            font-size: 14px;
            transition: opacity 0.2s;
        }

        .btn:hover { opacity: 0.8; }

        .btn-primary {
            background: #0095f6;
            color: white;
        }

        .btn-secondary {
            background: white;
            color: #262626;
            border: 1px solid #dbdbdb;
        }

        .btn-danger {
            background: #ed4956;
            color: white;
            padding: 4px 10px;
            font-size: 12px;
            border-radius: 6px;
        }

        .btn-copy {
            background: #efefef;
            color: #262626;
            padding: 4px 10px;
            font-size: 12px;
            border-radius: 6px;
        }

        .container {
            max-width: 100%;
            margin: 30px auto;
            padding: 0 40px;
        }

        .upload-card {
            background: white;
            border: 1px solid #dbdbdb;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .upload-card h3 {
            font-size: 16px;
            margin-bottom: 15px;
            color: #262626;
        }

        .upload-area {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .upload-area input[type="file"] {
            flex: 1;
            padding: 8px;
            border: 1px solid #dbdbdb;
            border-radius: 8px;
            font-size: 14px;
            cursor: pointer;
        }

        .chat-card {
            background: white;
            border: 1px solid #dbdbdb;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .chat-card input {
            flex: 1;
            padding: 10px 14px;
            border: 1px solid #dbdbdb;
            border-radius: 8px;
            font-size: 14px;
            outline: none;
        }

        .chat-card input:focus {
            border-color: #0095f6;
        }

        
        .files-card {
            background: white;
            border: 1px solid #dbdbdb;
            border-radius: 12px;
            overflow: hidden;
        }

        .files-header {
            padding: 15px 20px;
            border-bottom: 1px solid #dbdbdb;
            font-weight: 600;
            font-size: 15px;
        }

        .file-item {
            display: flex;
            align-items: center;
            padding: 12px 20px;
            border-bottom: 1px solid #fafafa;
            gap: 12px;
            transition: background 0.2s;
        }

        .file-item:hover { background: #fafafa; }
        .file-item:last-child { border-bottom: none; }

        .file-icon {
            font-size: 24px;
            width: 40px;
            text-align: center;
        }

        .file-info {
            flex: 1;
        }

        .file-name {
            font-size: 14px;
            font-weight: 500;
            color: #262626;
            text-decoration: none;
        }

        .file-name:hover { text-decoration: underline; }

        .file-actions {
            display: flex;
            gap: 6px;
        }

        .no-files {
            padding: 40px;
            text-align: center;
            color: #8e8e8e;
            font-size: 14px;
        }

        .alert {
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: #262626;
            color: white;
            padding: 10px 20px;
            border-radius: 8px;
            font-size: 14px;
            display: none;
        }
    </style>
</head>
<body>
    <div class="navbar">
        <h1>FileShare</h1>
        <div class="nav-buttons">
         <a href="/create-room"><button class="btn btn-primary">+ Create Room</button></a>
        </div>
    </div>
    <div class="container">
        <div class="upload-card">
            <h3>Upload File</h3>
    <form action="/upload" method="post" enctype="multipart/form-data">
        <div class="upload-area">
        <input type="file" name="profileImage">
        <button type="submit" class="btn btn-primary">upload</button>
        </div>
    </form>
    </div>
    <div class="chat-card">
      <form action="/join-room" method="get" style="display:flex; gap:10px; width:100%;">
         <input type="text" name="roomId" placeholder="Enter Room ID to join...">
         <button type="submit" class="btn btn-secondary">Join Room</button>
         </form>
        </div>
        <div class="files-card">
            <div class="files-header">📁 Your Files</div>
             <% if(files.length === 0) { %>
            <div class="no-files">No files uploaded yet!</div>
            <% } else { %>
            <% files.forEach(file => { %>
             <div class="file-item">
            <div class="file-icon">
            <% if(file.fileType === "application/pdf") { %>📄
            <% } else if(file.fileType.startsWith("image/")) { %>🖼️
            <% } else if(file.fileType.startsWith("video/")) { %>🎥
             <% } else if(file.fileType.startsWith("audio/")) { %>🎵
            <% } else { %>📎<% } %>
            </div>
            <div class="file-info">
        <%if(file.fileType === "application/pdf") { %>
            <a href="https://docs.google.com/viewer?url=<%= encodeURIComponent(file.url.replace('/upload/', '/upload/fl_attachment/')) %>" target="_blank">
                 <%= file.fileName %> 
            </a>
        <% } else { %>
            <a href="<%= file.url %>" target="_blank">
                 <%= file.fileName %>
            </a>
        <% } %>
        </div>
        <div class="file-actions">
            <button class="btn btn-copy" onclick="copyURL('<%=file.url%>')">Copy URL</button>
            <button class="btn btn-danger"  onclick="deleteFile('<%= file.id %>')"> Delete</button>
        </div>
        </div>
        <% }) %>
        <% } %> 
</div>
</div>
<div class="alert" id="alert">✅ URL Copied!</div>
<script src="/socket.io/socket.io.js"></script>
<script>
    const socket=io();
    function copyURL(url){
        navigator.clipboard.writeText(url); //browser built in api that copies to clipboard
        alert('URL Copied');
    }
      async function deleteFile(id) {
        await fetch(`/delete/${id}`, {
            method: "DELETE"
        });
        window.location.reload();
    }
</script>
</body>
</html>