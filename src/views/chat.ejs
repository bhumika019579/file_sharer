<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>chat room</title>
      <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        body {
            background: #f0f2f5;
            height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .navbar {
            background: white;
            border-bottom: 1px solid #dbdbdb;
            padding: 12px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .navbar h1 {
            font-size: 20px;
            font-weight: 700;
            background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .back-btn {
            background: none;
            border: none;
            font-size: 14px;
            color: #0095f6;
            cursor: pointer;
            font-weight: 600;
        }

        .copy-btn {
            background: #0095f6;
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            font-size: 13px;
        }

        .copy-btn:hover { opacity: 0.8; }

        .main {
            display: flex;
            flex: 1;
            overflow: hidden;
        }

        .sidebar {
            width: 280px;
            background: white;
            border-right: 1px solid #dbdbdb;
            display: flex;
            flex-direction: column;
            padding: 20px;
            gap: 20px;
        }

        .sidebar-section {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .sidebar-title {
            font-size: 13px;
            font-weight: 700;
            color: #8e8e8e;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .room-id-box {
            background: #f0f2f5;
            border-radius: 10px;
            padding: 12px;
            font-size: 12px;
            color: #262626;
            word-break: break-all;
            line-height: 1.5;
        }

        .username-input {
            padding: 10px 14px;
            border: 1px solid #dbdbdb;
            border-radius: 8px;
            font-size: 14px;
            outline: none;
            width: 100%;
        }

        .username-input:focus { border-color: #0095f6; }

        .users-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .user-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px;
            border-radius: 8px;
            background: #f0f2f5;
        }

        .user-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(45deg, #f09433, #bc1888);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 13px;
        }

        .user-name {
            font-size: 13px;
            font-weight: 500;
            color: #262626;
        }

        .online-dot {
            width: 8px;
            height: 8px;
            background: #4caf50;
            border-radius: 50%;
            margin-left: auto;
        }

        .chat-area {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .messages-container {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .message {
            display: flex;
            flex-direction: column;
            max-width: 60%;
        }

        .message.sent {
            align-self: flex-end;
            align-items: flex-end;
        }

        .message.received {
            align-self: flex-start;
            align-items: flex-start;
        }

        .message-sender {
            font-size: 11px;
            color: #8e8e8e;
            margin-bottom: 4px;
            padding: 0 4px;
        }

        .message-bubble {
            padding: 10px 14px;
            border-radius: 20px;
            font-size: 14px;
            line-height: 1.4;
            word-break: break-word;
        }

        .sent .message-bubble {
            background: #0095f6;
            color: white;
            border-bottom-right-radius: 4px;
        }

        .received .message-bubble {
            background: white;
            color: #262626;
            border-bottom-left-radius: 4px;
            box-shadow: 0 1px 2px rgba(0,0,0,0.1);
        }

        .message-bubble a { color: inherit; text-decoration: underline; word-break: break-all; }
        .message-bubble video, .message-bubble audio { max-width: 250px; border-radius: 12px; }

        .input-area {
            background: white;
            border-top: 1px solid #dbdbdb;
            padding: 12px 20px;
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .input-area input {
            flex: 1;
            padding: 10px 16px;
            border: 1px solid #dbdbdb;
            border-radius: 22px;
            font-size: 14px;
            outline: none;
        }

        .input-area input:focus { border-color: #0095f6; }

        .send-btn {
            background: #0095f6;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 22px;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
        }

        .send-btn:hover { opacity: 0.8; }

        .toast {
            position: fixed;
            bottom: 80px;
            left: 50%;
            transform: translateX(-50%);
            background: #262626;
            color: white;
            padding: 10px 20px;
            border-radius: 8px;
            font-size: 13px;
            display: none;
            z-index: 999;
        }
    </style>
</head>
<body>
     <div class="navbar">
        <a href="/"><button class="back-btn">← Back</button></a>
        <h1>FileShare</h1>
        <button class="copy-btn" onclick="copyRoomLink()">🔗 Copy Room Link</button>
    </div>

    <div class="main">
        <div class="sidebar">
           
            <div class="sidebar-section">
                <div class="sidebar-title">Your Name</div>
                <input type="text" id="username" class="username-input" placeholder="Enter your name">
            </div>
            <div class="sidebar-section">
                <div class="sidebar-title">Online Users</div>
                <div class="users-list" id="usersList"></div>
            </div>
        </div>

        <div class="chat-area">
            <div class="messages-container" id="messages"></div>
            <div class="input-area">
                <input type="text" id="messageInput" placeholder="Message..."
                       onkeypress="if(event.key==='Enter') Send_Message()">
                <button class="send-btn" onclick="Send_Message()">Send</button>
            </div>
        </div>
    </div>
       
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const Socket=io();
        const roomKey="<%=roomKey%>";
        Socket.emit("Join_Room",roomKey);
     document.getElementById("username").addEventListener("blur", () => {
    const username = document.getElementById("username").value;
    if(username) {
        Socket.emit("user-joined-name", { roomKey, username });
    }
});

Socket.on("user-joined-name", (Data) => {
    addUserToSidebar(Data.username);
});
       
        function Send_Message(){
            const message=document.getElementById("messageInput").value;
            const username=document.getElementById("username").value;
            console.log("Message:", message);
    console.log("Starts with http:", message.startsWith("http"));
            Socket.emit("Send_Message",{
                roomKey:roomKey,
                sender:username,
                message:message
            });
            document.getElementById("messageInput").value="";
        }
         const activeUsers = new Set();
        function addUserToSidebar(username) {
            if (activeUsers.has(username)) return;
            activeUsers.add(username);
            const usersList = document.getElementById("usersList");
            usersList.innerHTML += `
                <div class="user-item">
                    <div class="user-avatar">${username.charAt(0).toUpperCase()}</div>
                    <div class="user-name">${username}</div>
                    <div class="online-dot"></div>
                </div>
            `;
        }
        Socket.on("receive_message",(Data)=>{
            const messages=document.getElementById("messages");
            const currentUsername = document.getElementById("username").value;
            const isSent = (Data.sender === currentUsername);
            const isURL = Data.message.startsWith("http");
            let content="";
            if(isURL){
                const googleDocsFiles=[".pdf", ".docx"];
                const videoFiles = [".mp4", ".mov", ".avi"];
                const audioFiles = [".mp3", ".wav"];
                const isGoogleDocs = googleDocsFiles.some(ext => Data.message.endsWith(ext));
                const isVideo = videoFiles.some(ext => Data.message.endsWith(ext));
                const isAudio = audioFiles.some(ext => Data.message.endsWith(ext));
                if(isGoogleDocs){
                    content = `<a href="https://docs.google.com/viewer?url=${Data.message}" target="_blank">${Data.message}</a>`;
                }
                else if (isVideo){
                   content = `<video src="${Data.message}" controls></video>`;
                }
                else if (isAudio){
                   content = `<audio src="${Data.message}" controls></audio>`;
                }else {
                    content = `<a href="${Data.message}" target="_blank">${Data.message}</a>`;
                }
                } else{
                   content=Data.message;
                }  
                 addUserToSidebar(Data.sender);

            messages.innerHTML += `
                <div class="message ${isSent ? 'sent' : 'received'}">
                    <div class="message-sender">${Data.sender}</div>
                    <div class="message-bubble">${content}</div>
                </div>
            `;

            messages.scrollTop = messages.scrollHeight;               
            })
    </script>
</body>
</html>